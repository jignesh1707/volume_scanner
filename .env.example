# =============================================================================
#  .env.example — Volume Scanner
#  Copy to .env on the VPS and chmod 600 .env
# =============================================================================

# ── Shoonya (Finvasia) — daily login via NorenRestApiPy ──────────────────────
# Used by login_shoonya.py to mint a susertoken each morning. TOTP is prompted
# interactively (not stored on disk), the rest live here.

SHOONYA_USER=YOUR_USER_ID
SHOONYA_PASSWORD=YOUR_ACCOUNT_PASSWORD
SHOONYA_VENDOR_CODE=YOUR_USER_ID_U
SHOONYA_API_SECRET=YOUR_API_SECRET_FROM_PRISM
SHOONYA_IMEI=scanner1
