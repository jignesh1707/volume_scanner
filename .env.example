# =============================================================================
#  .env.example — Volume Scanner
#  Copy to .env on the VPS and chmod 600 .env
# =============================================================================

# ── Shoonya (Finvasia) — daily OAuth ─────────────────────────────────────────
SHOONYA_USER=YOUR_USER_ID
SHOONYA_APIKEY=YOUR_API_KEY

# One-time daily auth code from the browser OAuth flow.
# Normally produced by `python login_shoonya.py` which saves session_scanner.json;
# you only need this var if you want the service to recover from a cold start
# without running the helper script.
SHOONYA_AUTH_CODE=
